{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/about", "destination": "/about.html" },
    { "source": "/skills", "destination": "/skills.html" },
    { "source": "/projects", "destination": "/projects.html" },
    { "source": "/videos", "destination": "/videos.html" },
    { "source": "/gallery", "destination": "/gallery.html" },
    { "source": "/contact", "destination": "/contact.html" },
    { "source": "/a-propos", "destination": "/about.html" },
    { "source": "/competences", "destination": "/skills.html" },
    { "source": "/projets", "destination": "/projects.html" },
    { "source": "/galerie", "destination": "/gallery.html" }
  ],
  "redirects": [
    { "source": "/about.html", "destination": "/about", "permanent": true },
    { "source": "/skills.html", "destination": "/skills", "permanent": true },
    { "source": "/projects.html", "destination": "/projects", "permanent": true },
    { "source": "/videos.html", "destination": "/videos", "permanent": true },
    { "source": "/gallery.html", "destination": "/gallery", "permanent": true },
    { "source": "/contact.html", "destination": "/contact", "permanent": true },
    { "source": "/index.html", "destination": "/", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Powered-By", "value": "WordPress/6.4.2" },
        { "key": "X-Generator", "value": "WordPress 6.4.2" },
        { "key": "Link", "value": "</wp-content/themes/portfolio-theme/style.css>; rel=preload; as=style" }
      ]
    }
  ]
}
